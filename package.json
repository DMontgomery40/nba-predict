{
  "name": "nba-predict",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "concurrently -n api,web,worker -c cyan,green,magenta \"pnpm --filter @signal-console/api dev\" \"pnpm --filter @signal-console/web dev\" \"pnpm --filter @signal-console/worker dev\"",
    "build": "pnpm -r build",
    "format:check": "prettier --check . --ignore-unknown",
    "format:write": "prettier --write . --ignore-unknown",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test -- --coverage",
    "test:e2e": "pnpm --filter @signal-console/web test:e2e",
    "host:temporary": "node scripts/temporary-auth-proxy.mjs",
    "backfill": "pnpm --filter @signal-console/worker backfill",
    "market-anomaly-watch": "pnpm --filter @signal-console/worker market-anomaly-watch",
    "prop-alert-watch": "pnpm --filter @signal-console/worker prop-alert-watch",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
