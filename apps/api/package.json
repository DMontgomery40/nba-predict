{
  "name": "@signal-console/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/index.ts src/server.ts --format esm --out-dir dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@signal-console/adapters": "workspace:*",
    "@signal-console/domain": "workspace:*",
    "@signal-console/shared": "workspace:*",
    "fastify": "^5.2.2",
    "zod": "^3.24.3"
  }
}
